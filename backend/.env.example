ANTHROPIC_API_KEY=your_key_here
PORT=3000

# Set to "1" when deploying behind a reverse proxy (Railway, Render, Heroku, Fly.io).
# This lets Express read the real client IP from the proxy-injected X-Forwarded-For
# header so per-IP rate limiting works correctly in production.
# Leave unset for local development (uses raw socket IP, which cannot be spoofed).
TRUST_PROXY=

# Comma-separated list of allowed CORS origins for web clients.
# Leave blank to allow any origin (fine for a native-mobile-only app).
# Example: https://yourwebsite.com,https://app.yourwebsite.com
ALLOWED_ORIGINS=

# Postgres connection string. Auto-injected by the Railway Postgres plugin.
# If unset, battle logging silently no-ops and the leaderboard/admin endpoints
# return empty data. Set this in production to enable persistent stats.
DATABASE_URL=

# Static token guarding /admin/* routes. Generate a long random string
# (e.g. `openssl rand -hex 32`) and set it in Railway env. The same token is
# accepted via the `x-admin-secret` header or `?token=...` query string.
ADMIN_SECRET=
