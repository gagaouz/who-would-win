<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- No data is collected or linked to the user's identity. -->
    <key>NSPrivacyCollectedDataTypes</key>
    <array/>

    <!-- The app does NOT track users across apps and websites. -->
    <key>NSPrivacyTracking</key>
    <false/>

    <!-- No tracking domains used. -->
    <key>NSPrivacyTrackingDomains</key>
    <array/>

    <!-- Required-reason APIs used by the app and its SDKs. -->
    <key>NSPrivacyAccessedAPITypes</key>
    <array>
        <!-- UserDefaults — used to persist user settings (sound, haptics, purchase state). -->
        <!-- Reason: CA92.1 — accessing preferences/settings the user has defined. -->
        <dict>
            <key>NSPrivacyAccessedAPIType</key>
            <string>NSPrivacyAccessedAPICategoryUserDefaults</string>
            <key>NSPrivacyAccessedAPITypeReasons</key>
            <array>
                <string>CA92.1</string>
            </array>
        </dict>
    </array>
</dict>
</plist>
