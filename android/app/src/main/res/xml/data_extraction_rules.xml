<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ data-extraction rules. Controls what gets backed up to the cloud
  and what's allowed when transferring to a new device (device-to-device).
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="device_auth.xml"/>
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="device_auth.xml"/>
    </device-transfer>
</data-extraction-rules>
